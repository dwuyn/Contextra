# Local app / Prisma
DATABASE_URL=postgresql://contextra:contextra@localhost:5432/contextra?schema=public

# Docker Compose helpers.
# These are used by docker-compose.yml to build the container-side DATABASE_URL.
POSTGRES_DB=contextra
POSTGRES_USER=contextra
POSTGRES_PASSWORD=contextra

# Auth
# Generate a real secret with: openssl rand -base64 32
JWT_SECRET=development-secret-change-me

# OpenAI-compatible AI endpoint.
# The current code expects chat model "gemma4:31b-cloud" and embedding model
# "nomic-embed-text". If your provider uses different IDs, update the hard-coded
# model names in the source before running AI features.
# This localhost example is for running the app on the host via `npm run dev`.
# If you run the app container via Docker Compose, use a container-reachable URL.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=change-me

# Optional Redis for multi-instance SSE fan-out.
# Leave commented out for single-instance local development.
# REDIS_URL=redis://localhost:6379
