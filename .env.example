# Database
DATABASE_URL=postgresql://contextra:contextra@localhost:5432/contextra?schema=public

# Auth — REQUIRED. Generate a secure secret with: openssl rand -base64 32
# WARNING: The app will throw at startup if this is not set in production.
JWT_SECRET=development-secret-change-me

# Custom AI endpoint (llama.cpp / ollama / ngrok-proxied instance)
OPENAI_BASE_URL=https://your-ngrok-url.ngrok-free.dev/v1
OPENAI_API_KEY=sk-not-needed-for-local

# Optional: Redis for SSE horizontal scaling across multiple server instances.
# Omit this variable entirely to use the default single-instance in-memory mode.
REDIS_URL=redis://localhost:6379
