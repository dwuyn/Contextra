# Local app / Prisma
DATABASE_URL=postgresql://contextra:contextra@localhost:5432/contextra?schema=public
POSTGRES_DB=contextra
POSTGRES_USER=contextra
POSTGRES_PASSWORD=contextra

# Docker Compose helpers.
# DOCKER_BUILD_NETWORK=host
# APP_PORT=3000

# Auth
# Generate a real secret with: openssl rand -base64 32
JWT_SECRET=development-secret-change-me
AVATAR_STORAGE_DIR=./data/avatars

# Google Cloud Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS is only needed for local development with a service account key.
# When deployed on Google Cloud (Cloud Run, GKE, etc.), Application Default Credentials (ADC)
# are used automatically — do not set this variable in production.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-southeast1
# GOOGLE_APPLICATION_CREDENTIALS=./google-key.json

AI_CHAT_MODEL=gemini-2.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMENSIONS=768
AI_IMAGE_MODEL=imagen-4.0-generate-001
AI_IMAGE_LOCATION=global

# Google Cloud Text-to-Speech
# Use a service account JSON key file for local/self-hosted deployments.
# GOOGLE_APPLICATION_CREDENTIALS=./google-key.json
# Private GCS bucket used to persist cached segment audio.
GOOGLE_TTS_CACHE_BUCKET=contextra-voice-reader-cache
# Private GCS bucket used to persist generated chapter illustrations.
GOOGLE_CHAPTER_IMAGE_BUCKET=contextra-chapter-illustrations
# Region location for Gemini TTS model (default: us-central1 where the preview model is available)
GOOGLE_TTS_LOCATION=us-central1
GOOGLE_TTS_CURATED_VOICES_EN=Despina,Orus,Vindemiatrix,Charon
GOOGLE_TTS_CURATED_VOICES_VI=Despina,Orus,Vindemiatrix,Charon

# Optional Redis for multi-instance SSE fan-out.
# Leave commented out for single-instance local development.
# REDIS_URL=redis://localhost:6379
